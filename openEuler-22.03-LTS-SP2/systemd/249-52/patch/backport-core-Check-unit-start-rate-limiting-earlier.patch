diff --git a/src/core/service.c b/src/core/service.c
index c55304d170..9d8eef1f74 100644
--- a/src/core/service.c
+++ b/src/core/service.c
@@ -2436,13 +2436,6 @@ static int service_start(Unit *u) {
 
